{
    "name": "dereuromark/cakephp-workflow-demo",
    "description": "A runnable demo app showcasing the dereuromark/cakephp-workflow plugin: a software-release pipeline with manual + automatic + timeout transitions, a retry loop, conditional branching, guard blocks and command errors.",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "cakephp/cakephp": "5.3.*",
        "cakephp/migrations": "^5.0.0",
        "cakephp/plugin-installer": "^2.0",
        "dereuromark/cakephp-workflow": "dev-master",
        "friendsofcake/bootstrap-ui": "^5.0"
    },
    "require-dev": {
        "cakephp/bake": "^3.6.0",
        "cakephp/debug_kit": "^5.0.0",
        "phpunit/phpunit": "^13.1.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/",
            "Cake\\Test\\": "vendor/cakephp/cakephp/tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "cakephp/plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform-check": false,
        "sort-packages": true
    },
    "scripts": {
        "setup": [
            "@php -r \"@mkdir('tmp', 0777, true); @mkdir('logs', 0777, true); is_file('config/app_local.php') || copy('config/app_local.example.php', 'config/app_local.php');\"",
            "bin/cake migrations migrate -p Workflow",
            "bin/cake migrations migrate"
        ],
        "serve": "bin/cake server -p 8765",
        "test": "phpunit --colors=always"
    }
}
